<!-- One effect's parameters in the BeatFX section. The EffectSelector
     (effect name dropdown) now lives directly in effects.xml, right under
     the "BEAT FX" title, ahead of CH SELECT — this template only holds the
     per-slot level meter + beat-size control + on/off toggle ("parameters"). -->
<Template>
  <WidgetGroup>
    <ObjectName>BeatFX_Unit</ObjectName>
    <Layout>vertical</Layout>
    <Children>

      <VuMeter>
        <ObjectName>EffectMeter</ObjectName>
        <Size>0me,6max</Size>
        <PathBack scalemode="STRETCH">icons/effect_meter_bg.png</PathBack>
        <PathVu scalemode="STRETCH">icons/effect_meter_fg.png</PathVu>
        <Horizontal>true</Horizontal>
        <PeakHoldSize>0</PeakHoldSize>
        <PeakHoldTime>0</PeakHoldTime>
        <PeakFallTime>0</PeakFallTime>
        <PeakFallStep>0</PeakFallStep>
        <Connection>
          <ConfigKey>[EffectRack<Variable name="rack"/>_EffectUnit<Variable name="unit"/>_Effect<Variable name="effect"/>],meta</ConfigKey>
        </Connection>
      </VuMeter>

      <!-- BEAT FX SIZE — parameter 1 of the loaded effect (e.g. Echo's
           "Time", which has UnitsHint::Beats — its raw value IS already
           expressed directly in beats, range 0-2). BeatSpinBox shows/edits
           it as whole/fraction beat counts (4, 2, 1, 1/2, 1/4...) relative
           to the track's tempo, exactly like the Pioneer reference's beat
           readout, and halves/doubles on each arrow click. -->
      <WidgetGroup>
        <ObjectName>BeatFXSizeRow</ObjectName>
        <Layout>horizontal</Layout>
        <Size>0me,30max</Size>
        <Children>
          <EffectParameterName>
            <ObjectName>BeatFXSizeName</ObjectName>
            <Size>me,30max</Size>
            <EffectRack><Variable name="rack"/></EffectRack>
            <EffectUnit><Variable name="unit"/></EffectUnit>
            <Effect><Variable name="effect"/></Effect>
            <EffectParameter>1</EffectParameter>
            <Alignment>left</Alignment>
            <Elide>right</Elide>
          </EffectParameterName>
          <BeatSpinBox>
            <ObjectName>BeatFXSizeSpinBox</ObjectName>
            <Size>50f,30max</Size>
            <Value>[EffectRack<Variable name="rack"/>_EffectUnit<Variable name="unit"/>_Effect<Variable name="effect"/>],parameter1</Value>
          </BeatSpinBox>
        </Children>
      </WidgetGroup>

      <PushButton>
        <ObjectName>EffectToggle</ObjectName>
        <Size>0me,30max</Size>
        <NumberStates>2</NumberStates>
        <State>
          <Number>0</Number>
          <Text>Off</Text>
        </State>
        <State>
          <Number>1</Number>
          <Text>Active</Text>
        </State>
        <Connection>
          <ConfigKey>[EffectRack<Variable name="rack"/>_EffectUnit<Variable name="unit"/>_Effect<Variable name="effect"/>],enabled</ConfigKey>
          <ConnectValueToWidget>true</ConnectValueToWidget>
        </Connection>
        <Connection>
          <ConfigKey>[EffectRack<Variable name="rack"/>_EffectUnit<Variable name="unit"/>],group_[Master]_enable</ConfigKey>
          <ConnectValueToWidget>false</ConnectValueToWidget>
        </Connection>
        <Connection>
          <ConfigKey>[EffectRack<Variable name="rack"/>_EffectUnit<Variable name="unit"/>_Effect<Variable name="effect"/>],meta</ConfigKey>
          <ConnectValueToWidget>false</ConnectValueToWidget>
        </Connection>
      </PushButton>

    </Children>

    <!-- Highlights this effect unit when selected -->
    <Connection>
      <ConfigKey>[EffectRack<Variable name="rack"/>_EffectUnit<Variable name="unit"/>],focused_effect</ConfigKey>
      <BindProperty>highlight</BindProperty>
      <Transform>
        <IsEqual><Variable name="effect"/></IsEqual>
      </Transform>
    </Connection>

  </WidgetGroup>
</Template>
