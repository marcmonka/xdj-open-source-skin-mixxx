<Template>
  <WidgetGroup>
    <ObjectName>Topbar</ObjectName>
    <Layout>vertical</Layout>
    <Size>100me,28f</Size>
    <Children>
      <WidgetGroup>
          <ObjectName>FonsBarra</ObjectName>
          <Layout>horizontal</Layout>
              <Size>100me,28f</Size>
          <Children>

              <WidgetGroup><Size>0me,28f</Size></WidgetGroup> <!-- left flexible spacer, centers the cluster below -->

              <!-- System clock -->
              <WidgetGroup>
                <ObjectName>TopbarClockWrapper</ObjectName>
                <Layout>horizontal</Layout>
                <Size>60f,28f</Size>
                <Children>
                  <Time>
                    <ObjectName>TopbarClock</ObjectName>
                    <TooltipId>time</TooltipId>
                    <Size>60f,28f</Size>
                    <Alignment>center</Alignment>
                  </Time>
                </Children>
              </WidgetGroup>

              <WidgetGroup><Size>12f,28f</Size></WidgetGroup>

              <!-- Recording status: small circle (grey idle, red while
                   actually recording) + duration -->
              <WidgetGroup>
                <ObjectName>TopbarRecWrapper</ObjectName>
                <Layout>horizontal</Layout>
                <Size>70f,28f</Size>
                <Children>
                  <Label>
                    <ObjectName>TopbarRecCircle</ObjectName>
                    <Text>&#9679;</Text>
                    <Connection>
                      <ConfigKey>[Recording],status</ConfigKey>
                      <BindProperty>highlight</BindProperty>
                    </Connection>
                  </Label>
                  <WidgetGroup><Size>4f,28f</Size></WidgetGroup>
                  <RecordingDuration>
                    <ObjectName>TopbarRecDuration</ObjectName>
                    <Size>60f,28f</Size>
                    <InactiveText>REC</InactiveText>
                    <Alignment>center</Alignment>
                    <Connection>
                      <ConfigKey>[Recording],status</ConfigKey>
                      <BindProperty>highlight</BindProperty>
                    </Connection>
                  </RecordingDuration>
                </Children>
              </WidgetGroup>

              <WidgetGroup><Size>12f,28f</Size></WidgetGroup>

              <!-- Master output level, L+R, green→orange→red gradient
                   (master_vu_fg.png). NOTE: the real ControlObjects are
                   [Main],vu_meter_left/_right — [Master],VuMeter* only
                   exists as a differently-cased alias ("VuMeter", not
                   "vu_meter"), so the previous lowercase ConfigKey matched
                   nothing and the meter never moved at all. -->
              <WidgetGroup>
                <ObjectName>TopbarMasterVuWrapper</ObjectName>
                <Layout>vertical</Layout>
                <Size>70f,28f</Size>
                <Children>
                  <VuMeter>
                    <ObjectName>TopbarMasterVuL</ObjectName>
                    <TooltipId>master_vu_meter</TooltipId>
                    <Size>70f,4f</Size>
                    <PathBack scalemode="STRETCH">icons/effect_meter_bg.png</PathBack>
                    <PathVu scalemode="STRETCH">icons/master_vu_fg.png</PathVu>
                    <Horizontal>true</Horizontal>
                    <PeakHoldSize>5</PeakHoldSize>
                    <PeakHoldTime>300</PeakHoldTime>
                    <PeakFallTime>20</PeakFallTime>
                    <PeakFallStep>1</PeakFallStep>
                    <Connection>
                      <ConfigKey>[Main],vu_meter_left</ConfigKey>
                    </Connection>
                  </VuMeter>
                  <WidgetGroup><Size>70f,1f</Size></WidgetGroup>
                  <VuMeter>
                    <ObjectName>TopbarMasterVuR</ObjectName>
                    <TooltipId>master_vu_meter</TooltipId>
                    <Size>70f,4f</Size>
                    <PathBack scalemode="STRETCH">icons/effect_meter_bg.png</PathBack>
                    <PathVu scalemode="STRETCH">icons/master_vu_fg.png</PathVu>
                    <Horizontal>true</Horizontal>
                    <PeakHoldSize>5</PeakHoldSize>
                    <PeakHoldTime>300</PeakHoldTime>
                    <PeakFallTime>20</PeakFallTime>
                    <PeakFallStep>1</PeakFallStep>
                    <Connection>
                      <ConfigKey>[Main],vu_meter_right</ConfigKey>
                    </Connection>
                  </VuMeter>
                </Children>
              </WidgetGroup>

              <WidgetGroup><Size>0me,28f</Size></WidgetGroup> <!-- right flexible spacer -->

              <!-- Library/Browse navigation — both buttons share the same
                   spot; only one is ever visible, depending on [Tab],library
                   (the WidgetStack resets the OTHER page's trigger key to 0
                   whenever a page switches, src/widget/wwidgetstack.cpp
                   onCurrentWidgetChanged, so this toggle is always correct). -->
              <WidgetGroup>
                <ObjectName>TabControls</ObjectName>
                <Layout>horizontal</Layout>
                <Size>90f,28f</Size>
                <Children>
                  <PushButton>
                    <ObjectName>NavBrowseBtn</ObjectName>
                    <Size>90f,28f</Size>
                    <NumberStates>2</NumberStates>
                    <State><Number>0</Number><Text>BROWSE</Text></State>
                    <State><Number>1</Number><Text>BROWSE</Text></State>
                    <Connection>
                      <ConfigKey>[Tab],library</ConfigKey>
                    </Connection>
                    <Connection>
                      <ConfigKey>[Tab],library</ConfigKey>
                      <BindProperty>visible</BindProperty>
                      <Transform><Not/></Transform>
                    </Connection>
                  </PushButton>
                  <PushButton>
                    <ObjectName>NavBackBtn</ObjectName>
                    <Size>90f,28f</Size>
                    <NumberStates>2</NumberStates>
                    <State><Number>0</Number><Text>BACK</Text></State>
                    <State><Number>1</Number><Text>BACK</Text></State>
                    <Connection>
                      <ConfigKey>[Tab],overview</ConfigKey>
                    </Connection>
                    <Connection>
                      <ConfigKey>[Tab],library</ConfigKey>
                      <BindProperty>visible</BindProperty>
                    </Connection>
                  </PushButton>
                </Children>
              </WidgetGroup>

              <WidgetGroup><Size>8f,28f</Size></WidgetGroup>

              <!-- Settings (recording + waveform color) — reuses the
                   "shortcut" page/[Tab],shortcut trigger already wired in
                   skin.xml, just with a gear icon instead of the old
                   "SHORTCUT" text -->
              <WidgetGroup>
                <ObjectName>TabControls</ObjectName>
                <Layout>horizontal</Layout>
                <Size>40f,28f</Size>
                <Children>
                  <Template src="skin:tab.xml">
                    <SetVariable name="tab_name">&#9881;</SetVariable>
                    <SetVariable name="config_key">shortcut</SetVariable>
                  </Template>
                </Children>
              </WidgetGroup>

           </Children>
        </WidgetGroup>

    </Children>
 </WidgetGroup>
</Template>
